{
  "name": "@semantic-authority/cli",
  "version": "0.2.0-alpha",
  "description": "Validate, enforce, and generate agent context from MEANING.yaml",
  "license": "MIT",
  "author": "Samson Aligba <hello@samsonaligba.com>",
  "homepage": "https://github.com/ai-native-pm-stack/semantic-authority",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-native-pm-stack/semantic-authority"
  },
  "bin": {
    "meaning": "./dist/index.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "src/schema/meaning.schema.json"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/schema && cp src/schema/meaning.schema.json dist/schema/meaning.schema.json",
    "dev": "tsx src/index.ts",
    "test": "npm run build && node --test tests/*.test.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^13.1.0",
    "yaml": "^2.7.0",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "semantic-authority",
    "meaning",
    "governance",
    "constraints",
    "ai-agents",
    "drift-detection",
    "claude",
    "cursor"
  ]
}
